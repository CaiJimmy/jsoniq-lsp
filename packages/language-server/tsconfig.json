{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "declaration": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "paths": {
            "grammar/*": [
                "./src/grammar/*"
            ],
            "server/*": [
                "./src/server/*"
            ]
        }
    },
    "include": [
        "src",
    ]
}